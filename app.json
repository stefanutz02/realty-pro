{
  "expo": {
    "name": "RealtyPro",
    "slug": "realty-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.svg",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,

    "splash": {
      "image": "./assets/splash-icon.svg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },

    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.realtypro.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-foreground.svg",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "INTERNET",
        "POST_NOTIFICATIONS",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK"
      ],
      "edgeToEdgeEnabled": true,
      "package": "com.realtypro.app"
    },

    "web": {
      "favicon": "./assets/favicon.svg"
    },

    "plugins": [
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": true,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          },
          "ios": {
            "newArchEnabled": true
          }
        }
      ]
    ],

    "extra": {
      "eas": {
        "projectId": "realty-pro-project-id"
      }
    }
  }
}
